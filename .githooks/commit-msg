#!/bin/sh

MSG_FILE="$1"
FIRST_LINE=$(head -n 1 "$MSG_FILE")

PATTERN='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._/-]+\))?(!)?: .+$'

if ! printf '%s' "$FIRST_LINE" | grep -Eq "$PATTERN"; then
  echo "[commit-msg] Conventional Commits 형식이 아닙니다." >&2
  echo "[commit-msg] 예시: feat(wedding): add share button state" >&2
  exit 1
fi

LEN=$(printf '%s' "$FIRST_LINE" | wc -c | tr -d ' ')
if [ "$LEN" -gt 73 ]; then
  echo "[commit-msg] 제목은 72자 이내여야 합니다. 현재: $((LEN-1))자" >&2
  exit 1
fi

case "$FIRST_LINE" in
  *.)
    echo "[commit-msg] 제목 끝 마침표(.)를 제거하세요." >&2
    exit 1
    ;;
esac

exit 0
